{
  "name": "objgauss-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5395 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5395 --strictPort",
    "audit:demo": "node scripts/audit-demo.mjs",
    "audit:commercial-demo-readiness": "node scripts/audit-commercial-demo-readiness.mjs",
    "audit:hard-mask-quality": "node scripts/audit-hard-mask-quality.mjs",
    "audit:object-mask-boundary": "node scripts/audit-object-mask-boundary.mjs",
    "audit:object-boundary-cleanup": "node scripts/audit-object-mask-boundary.mjs --assets nerf-lego-alpha-closure-local,plush-semantic-closure-local,polyhaven-chair-commercial-demo-local --output-dir /tmp/objgauss-object-boundary-cleanup",
    "audit:object-boundary-remap-preview": "node scripts/export-object-boundary-remap-preview.mjs --output-dir /tmp/objgauss-object-boundary-remap-preview",
    "audit:object-boundary-remap-residual": "node scripts/audit-object-boundary-remap-residual.mjs --output-dir /tmp/objgauss-object-boundary-remap-residual",
    "audit:object-boundary-remap-target-sweep": "node scripts/audit-object-boundary-remap-residual.mjs --target-count 2 --output-dir /tmp/objgauss-object-boundary-remap-target-sweep",
    "audit:object-boundary-remap-policy": "node scripts/audit-object-boundary-remap-residual.mjs --target-count 2 --output-dir /tmp/objgauss-object-boundary-remap-policy",
    "audit:object-boundary-remap-policy-export": "node scripts/export-object-boundary-remap-preview.mjs --assets nerf-lego-alpha-closure-local,plush-semantic-closure-local,polyhaven-chair-commercial-demo-local --policy /tmp/objgauss-object-boundary-remap-policy/remap-decision-policy.json --reviewed-allowlist docs/rendering/object-boundary-remap-reviewed-allowlist.json --output-dir /tmp/objgauss-object-boundary-remap-policy-export",
    "audit:object-boundary-remap-reviewed-allowlist-manifest": "node scripts/audit-object-boundary-remap-reviewed-allowlist-manifest.mjs",
    "audit:object-boundary-remap-reviewed-allowlist": "node scripts/audit-object-boundary-remap-reviewed-allowlist.mjs",
    "audit:webgpu-runtime": "node scripts/audit-demo.mjs --require-webgpu --webgpu-flags unsafe",
    "audit:webgpu-probe": "node scripts/audit-demo.mjs --require-webgpu --webgpu-flags unsafe --allow-webgpu-device-lost --webgpu-probe accumulation-only",
    "audit:webgpu-offscreen-readback": "node scripts/audit-webgpu-offscreen-readback.mjs",
    "audit:webgpu-runtime-performance": "node scripts/audit-webgpu-runtime-performance.mjs",
    "audit:webgpu-presentation-performance": "node scripts/audit-webgpu-presentation-performance.mjs",
    "audit:webgpu-presentation-transition": "node scripts/audit-webgpu-presentation-transition.mjs",
    "audit:webgpu-frame-pacing": "node scripts/audit-webgpu-frame-pacing.mjs",
    "audit:webgpu-synthetic-1m-runtime": "node scripts/audit-webgpu-synthetic-1m-runtime.mjs",
    "audit:webgpu-ply-runtime": "node scripts/audit-webgpu-ply-runtime.mjs",
    "audit:webgpu-sustained-frame-pacing": "node scripts/audit-webgpu-sustained-frame-pacing.mjs",
    "audit:webgpu-cpath-production-sla": "node scripts/audit-webgpu-cpath-production-sla.mjs",
    "audit:webgpu-desktop": "node scripts/audit-webgpu-desktop.mjs",
    "audit:webgpu-coverage-sweep": "node scripts/audit-webgpu-coverage-sweep.mjs",
    "audit:webgpu-coverage-gate": "node scripts/audit-webgpu-coverage-sweep.mjs --assets nerf-lego-alpha-closure-local,plush-semantic-closure-local --output-dir /tmp/objgauss-webgpu-coverage-sweep-gate --gate-variant baseline --max-mean-pareto-score 1 --max-mean-luma-norm 1 --max-mean-chroma-norm 1 --max-scene-pareto-score 1 --max-scene-luma-norm 1 --max-scene-chroma-norm 1",
    "audit:webgpu-alpha-floor-sweep": "node scripts/audit-webgpu-coverage-sweep.mjs --assets nerf-lego-alpha-closure-local,plush-semantic-closure-local --variants baseline:2.2:4:0.035,alpha05:2.2:4:0.05,alpha075:2.2:4:0.075,alpha10:2.2:4:0.1 --output-dir /tmp/objgauss-webgpu-alpha-floor-sweep",
    "audit:webgpu-alpha-floor-candidate-gate": "node scripts/audit-webgpu-coverage-sweep.mjs --assets nerf-lego-alpha-closure-local,plush-semantic-closure-local --variants baseline:2.2:4:0.035,alpha05:2.2:4:0.05,alpha075:2.2:4:0.075,alpha10:2.2:4:0.1 --output-dir /tmp/objgauss-webgpu-alpha-floor-candidate-gate --gate-variant alpha10 --max-mean-pareto-score 1 --max-mean-luma-norm 1 --max-mean-chroma-norm 1 --max-scene-pareto-score 1 --max-scene-luma-norm 1 --max-scene-chroma-norm 1",
    "audit:spark-reconstruct-residual": "node scripts/audit-spark-reconstruct-residual.mjs --assets nerf-lego-alpha-closure-local --output-dir /tmp/objgauss-spark-reconstruct-residual",
    "audit:spark-reconstruct-residual-multiscene": "node scripts/audit-spark-reconstruct-residual.mjs --assets nerf-lego-alpha-closure-local,plush-semantic-closure-local --output-dir /tmp/objgauss-spark-reconstruct-residual-multiscene",
    "audit:spark-mask-feather": "node scripts/audit-demo.mjs --assets nerf-lego-alpha-closure-local --skip-visual-residual --server-mode preview --port 5395 --spark-object-mask-feather --spark-object-mask-feather-opacity 0.55",
    "audit:spark-mask-feather-sweep": "node scripts/audit-spark-mask-feather-sweep.mjs",
    "audit:spark-mask-feather-candidates": "node scripts/audit-spark-mask-feather-sweep.mjs --assets nerf-lego-alpha-closure-local,plush-semantic-closure-local,polyhaven-chair-commercial-demo-local --variants hard:off,feather55:0.55,feather70:0.70,feather55r035:0.55:0.035 --output-dir /tmp/objgauss-spark-mask-feather-candidates --skip-missing-assets",
    "audit:spark-native-mask-gate": "node scripts/audit-spark-native-mask-gate.mjs",
    "audit:spark-native-pick-feasibility": "node scripts/audit-spark-native-pick-feasibility.mjs",
    "audit:spark-pick-report": "node scripts/audit-spark-pick-report.mjs",
    "audit:spark-trained-sample": "node scripts/audit-spark-trained-sample.mjs",
    "audit:spark-trained-route": "node scripts/audit-spark-trained-route.mjs",
    "audit:splat-index-mapping": "node scripts/audit-splat-index-mapping.mjs --output-dir /tmp/objgauss-splat-index-mapping",
    "audit:webgpu-depth-sweep": "node scripts/audit-webgpu-depth-sweep.mjs",
    "audit:webgpu-tile-smoke": "node scripts/audit-webgpu-tile-smoke.mjs",
    "audit:webgpu-scale-budget": "node scripts/audit-webgpu-scale-budget.mjs",
    "audit:webgpu-edit-cost-budget": "node scripts/audit-webgpu-edit-cost-budget.mjs",
    "audit:webgpu-cpath-readiness": "node scripts/audit-webgpu-cpath-readiness.mjs",
    "audit:renderer-route-contract": "node scripts/audit-renderer-route-contract.mjs",
    "acceptance:renderer": "node scripts/acceptance-renderer-profile.mjs",
    "acceptance:renderer-ci": "node scripts/acceptance-renderer-profile.mjs --profile ci",
    "acceptance:renderer-product": "node scripts/acceptance-renderer-profile.mjs --profile product",
    "acceptance:demo": "node scripts/acceptance-demo.mjs",
    "acceptance:semantic": "node scripts/acceptance-semantic-benchmark.mjs",
    "acceptance:webgpu-headless": "node scripts/acceptance-webgpu-headless.mjs",
    "acceptance:spark-commercial-route": "node scripts/acceptance-spark-commercial-route.mjs",
    "publish:polyhaven-chair-demo": "node scripts/publish-polyhaven-chair-demo.mjs",
    "train:splatfacto:smoke": "node scripts/train-splatfacto-smoke.mjs",
    "train:splatfacto:near1m-candidate": "node scripts/train-splatfacto-near1m-candidate.mjs",
    "train:splatfacto:near1m-gpu-preflight": "node scripts/train-splatfacto-near1m-candidate.mjs --gpu-preflight-only",
    "train:splatfacto:near1m-background": "node scripts/launch-splatfacto-near1m-background.mjs",
    "benchmark:splatfacto:balanced": "node scripts/benchmark-splatfacto-balanced.mjs",
    "benchmark:splatfacto:variants": "node scripts/benchmark-splatfacto-variants.mjs",
    "benchmark:splatfacto:scenes": "node scripts/benchmark-splatfacto-scenes.mjs",
    "benchmark:cross-scene": "node scripts/benchmark-cross-scene.mjs"
  },
  "dependencies": {
    "@sparkjsdev/spark": "^2.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.180.0",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  }
}
